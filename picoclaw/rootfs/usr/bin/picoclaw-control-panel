      try {
        const response = await fetch(addonUrl(url), { method: 'POST' });
        const rawText = await response.text();
        let data;
        try {
          data = JSON.parse(rawText);
        } catch (parseError) {
          throw new Error('非 JSON 响应: ' + rawText.slice(0, 500));
        }
        const ok = !!data.ok;
        setStatus(prefix, ok, ok ? '通过' : '失败');
        document.getElementById(targetId).textContent = JSON.stringify(data, null, 2);
      } catch (error) {
        setStatus(prefix, false, '请求失败');
        document.getElementById(targetId).textContent = error.toString();
