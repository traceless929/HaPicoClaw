    function addonUrl(path) {
      return new URL(path, new URL('./', window.location.href)).toString();
    }

    function setStatus(prefix, ok, text) {
      const el = document.getElementById(prefix + '-status');
      el.textContent = text;
      el.className = 'status ' + (ok === null ? 'pending' : ok ? 'ok' : 'fail');
