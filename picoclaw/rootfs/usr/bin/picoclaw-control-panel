def json_response(result, status=200):
    return web.Response(
        text=json.dumps(result, ensure_ascii=False, indent=2),
        status=status,
        content_type="application/json",
    )


async def run_command(command):
    process = await asyncio.create_subprocess_exec(
        *command,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    stdout, stderr = await process.communicate()
    stdout_text = stdout.decode("utf-8", errors="replace")
    stderr_text = stderr.decode("utf-8", errors="replace")
    payload = {}
    if stdout_text.strip():
        try:
            payload = json.loads(stdout_text)
        except json.JSONDecodeError:
            payload = {"ok": False, "summary": "invalid JSON output", "details": {"stdout": stdout_text}}
    else:
        payload = {"ok": process.returncode == 0, "summary": "no output", "details": {}}

    payload.setdefault("details", {})
    payload["details"]["stderr"] = stderr_text.strip()
    payload["details"]["returncode"] = process.returncode
    return payload


async def index(request):
    return web.Response(text=INDEX_HTML, content_type="text/html")


async def mcp_check(request):
    return json_response(await run_command(["/usr/bin/ha-mcp-selftest", "--json"]))


async def ha_api_check(request):
    return json_response(await run_command(["/usr/bin/ha-api-selftest", "--json"]))


async def supervisor_api_check(request):
    return json_response(await run_command(["/usr/bin/supervisor-api-selftest", "--json"]))


async def all_checks(request):
    mcp = await run_command(["/usr/bin/ha-mcp-selftest", "--json"])
    ha_api = await run_command(["/usr/bin/ha-api-selftest", "--json"])
    supervisor = await run_command(["/usr/bin/supervisor-api-selftest", "--json"])
    ok = all(item.get("ok") for item in (mcp, ha_api, supervisor))
    return json_response(
        {
            "ok": ok,
            "summary": "All diagnostics passed" if ok else "One or more diagnostics failed",
            "details": {
                "mcp": mcp,
                "ha_api": ha_api,
                "supervisor_api": supervisor,
            },
        }
    )


async def restart_gateway(request):
    restart_file = Path("/data/picoclaw/restart-gateway")
    restart_file.touch()
    return json_response(
        {
            "ok": True,
            "summary": "Gateway restart requested",
            "details": {"path": str(restart_file)},
        }
    )


def filter_proxy_headers(headers):
    blocked = {
        "host",
        "content-length",
        "transfer-encoding",
        "content-encoding",
        "accept-encoding",
        "connection",
        "upgrade",
        "keep-alive",
        "proxy-authenticate",
        "proxy-authorization",
        "te",
        "trailers",
    }
    return {key: value for key, value in headers.items() if key.lower() not in blocked}


def build_upstream_headers(headers):
    upstream_headers = filter_proxy_headers(headers)
    # Avoid compressed asset responses from ttyd so HA Ingress and the browser
    # see a normal decoded body with matching headers.
    upstream_headers["Accept-Encoding"] = "identity"
    return upstream_headers


async def proxy_terminal(request):
    upstream_url = f"{TTYD_BASE_URL}{request.path}"
    if request.query_string:
        upstream_url = f"{upstream_url}?{request.query_string}"

    ws_probe = web.WebSocketResponse()
    ws_ready = ws_probe.can_prepare(request)
    if ws_ready.ok:
        client_ws = web.WebSocketResponse()
        await client_ws.prepare(request)
        async with ClientSession() as session:
            async with session.ws_connect(upstream_url, headers=build_upstream_headers(request.headers)) as upstream_ws:
                async def client_to_upstream():
                    async for msg in client_ws:
                        if msg.type == WSMsgType.TEXT:
                            await upstream_ws.send_str(msg.data)
                        elif msg.type == WSMsgType.BINARY:
                            await upstream_ws.send_bytes(msg.data)
                        elif msg.type == WSMsgType.CLOSE:
                            await upstream_ws.close()

                async def upstream_to_client():
                    async for msg in upstream_ws:
                        if msg.type == WSMsgType.TEXT:
                            await client_ws.send_str(msg.data)
                        elif msg.type == WSMsgType.BINARY:
                            await client_ws.send_bytes(msg.data)
                        elif msg.type == WSMsgType.CLOSE:
                            await client_ws.close()

                await asyncio.gather(client_to_upstream(), upstream_to_client())
        return client_ws

    body = await request.read()
    async with ClientSession() as session:
        async with session.request(
            request.method,
            upstream_url,
            headers=build_upstream_headers(request.headers),
            data=body,
            allow_redirects=False,
            skip_auto_headers={"Accept-Encoding"},
        ) as upstream_response:
            response_body = await upstream_response.read()
            response = web.Response(status=upstream_response.status, body=response_body)
            for key, value in upstream_response.headers.items():
                if key.lower() in {"content-length", "transfer-encoding", "connection", "content-encoding"}:
                    continue
                response.headers[key] = value
            return response


def create_app():
    app = web.Application(client_max_size=10 * 1024 * 1024)
    app.router.add_get("/", index)
    app.router.add_post("/api/diagnostics/mcp", mcp_check)
    app.router.add_post("/api/diagnostics/ha-api", ha_api_check)
    app.router.add_post("/api/diagnostics/supervisor-api", supervisor_api_check)
    app.router.add_post("/api/diagnostics/all", all_checks)
    app.router.add_post("/api/actions/restart-gateway", restart_gateway)
    app.router.add_route("*", "/terminal{tail:.*}", proxy_terminal)
    return app


def main():
    web.run_app(create_app(), host=LISTEN_HOST, port=LISTEN_PORT)


if __name__ == "__main__":
    main()
