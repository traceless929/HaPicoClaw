#!/usr/bin/env python3
import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request


def emit(result, json_mode):
    if json_mode:
        print(json.dumps(result, ensure_ascii=False))
    else:
        print(f"Supervisor API self-test: {result['summary']}", file=sys.stderr, flush=True)
        if result.get("details"):
            print(
                f"Supervisor API self-test details: {json.dumps(result['details'], ensure_ascii=False)}",
                file=sys.stderr,
                flush=True,
            )
    return 0 if result["ok"] else 1


def build_result(ok, summary, **details):
    return {"ok": ok, "summary": summary, "details": details}


def request_json(url, token):
    request = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Bearer {token}",
            "Accept": "application/json",
        },
        method="GET",
    )
    with urllib.request.urlopen(request, timeout=15) as response:
        body = response.read().decode("utf-8", errors="replace")
        return response.status, json.loads(body) if body else {}


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args()

    token = os.environ.get("SUPERVISOR_TOKEN", "").strip()
    if not token:
        return emit(
            build_result(False, "SUPERVISOR_TOKEN missing, unable to call Supervisor API"),
            args.json,
        )

    candidate_urls = [
        "http://supervisor/supervisor/info",
        "http://supervisor/addons/self/info",
    ]

    errors = []
    for url in candidate_urls:
        start = time.monotonic()
        try:
            status, parsed = request_json(url, token)
            duration_ms = int((time.monotonic() - start) * 1000)
            return emit(
                build_result(
                    True,
                    "Supervisor API reachable",
                    url=url,
                    http_status=status,
                    duration_ms=duration_ms,
                    keys=sorted(parsed.keys()),
                ),
                args.json,
            )
        except urllib.error.HTTPError as exc:
            duration_ms = int((time.monotonic() - start) * 1000)
            body = exc.read().decode("utf-8", errors="replace")
            errors.append(
                {
                    "url": url,
                    "http_status": exc.code,
                    "duration_ms": duration_ms,
                    "body": body[:500],
                }
            )
        except Exception as exc:
            duration_ms = int((time.monotonic() - start) * 1000)
            errors.append(
                {
                    "url": url,
                    "duration_ms": duration_ms,
                    "error": str(exc),
                }
            )

    return emit(
        build_result(False, "Supervisor API request failed", attempts=errors),
        args.json,
    )


if __name__ == "__main__":
    sys.exit(main())
